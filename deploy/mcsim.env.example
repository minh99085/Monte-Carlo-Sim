# mcsim.env — environment for the Monte-Carlo-Sim deployment.
# Copy to /etc/monte-carlo-sim/mcsim.env and `chmod 600` it (it holds secrets).
# Read by every systemd unit via EnvironmentFile=. Never commit the real file.

# ── Webhook bridge auth (required) ────────────────────────────────────────
# Long random string; TradingView must send it as ?secret=... or the
# X-Webhook-Secret header. Generate: openssl rand -hex 32
TV_BRIDGE_SECRET=CHANGE_ME_LONG_RANDOM_STRING

# Optional HMAC-SHA256 body signing key (defense in depth). Leave blank to
# disable. If set, every webhook body must carry a matching
# X-Signature-SHA256 header. Generate: openssl rand -hex 32
TV_BRIDGE_HMAC_KEY=

# Bridge bind address/port.
#
# DEFAULT (simple): 0.0.0.0 means the bridge listens on the server's public
# IP directly, so TradingView can reach it at http://YOUR_IP:5001/webhook —
# no domain, no HTTPS. This matches many TradingView bot setups; the
# tradeoff is that alert data (and the ?secret=... in the URL) travels
# unencrypted. If that's an acceptable tradeoff for you, leave this as-is.
#
# MORE SECURE (optional): if you set up Caddy for HTTPS (see
# deploy/README.md), change this to 127.0.0.1 so only Caddy (not the whole
# internet) can reach the bridge directly.
TV_BRIDGE_HOST=0.0.0.0
# NOTE: TradingView only accepts plain-HTTP webhook URLs on port 80, so for
# a direct http://YOUR_IP/webhook?... alert set TV_BRIDGE_PORT=80 (the
# systemd unit grants the low-port capability). 5001 remains fine when
# something else (Caddy, a port redirect) fronts the bridge.
TV_BRIDGE_PORT=5001

# Seconds within which an identical consecutive signal is deduped (history
# only, latest_signal.json timestamp preserved). 0 disables.
TV_BRIDGE_DEDUPE_WINDOW=600

# ── Decision layer (run_weekly_from_tv.py) ────────────────────────────────
# Reject signals older than this many hours as stale (no verdict).
MC_MAX_AGE_HOURS=30
# Monte Carlo paths per verdict, cost per side (bps as a fraction), account
# size for sizing, and stop distance in weekly-sigma multiples.
MC_PATHS=100000
MC_COST=0.0005
MC_ACCOUNT=100000
MC_STOP_MULT=1.5

# ── Calibration (signal_calibration.py) ───────────────────────────────────
# Space-separated tickers to (re)calibrate monthly. Must cover every ticker
# your TradingView alerts can name, or those signals get NO_TRADE
# ("no calibration table").
MC_TICKERS=AAPL MSFT NVDA
# Years of history per calibration.
MC_YEARS=8
